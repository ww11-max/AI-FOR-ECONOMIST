# eco-acquire 环境变量配置
# 复制此文件为 .env 并修改

# ============================================================
# 浏览器配置
# ============================================================
# 浏览器选择：auto / chrome / edge / firefox
# auto = 自动检测系统已安装的浏览器（Chrome > Edge > Firefox）
BROWSER=auto

# 无头模式（不显示浏览器窗口）
USE_HEADLESS=False

# 调试模式
DEBUG=True

# 禁用SSL证书验证（仅在有证书问题时启用，默认false）
UNSAFE_SSL=False

# ============================================================
# 爬虫行为
# ============================================================
MAX_RETRIES=3
REQUEST_TIMEOUT=30
WAIT_TIME_MIN=2.0
WAIT_TIME_MAX=5.0
MAX_WORKERS=2

# ============================================================
# 备用下载渠道（无CNKI权限时自动启用）
# ============================================================
# 是否启用备用下载渠道
ENABLE_FALLBACK=True

# Unpaywall API邮箱（推荐填写，用于合法OA论文检索）
UNPAYWALL_EMAIL=your_email@example.com

# 自定义Sci-Hub域名（逗号分隔，留空则禁用Sci-Hub渠道）
# 示例: SCIHUB_DOMAINS=https://sci-hub.se,https://sci-hub.st
SCIHUB_DOMAINS=

# 备用下载超时（秒）
FALLBACK_DOWNLOAD_TIMEOUT=60

# ============================================================
# 数据目录
# ============================================================
# 输出/下载/日志的存放位置，默认 ~/eco-acquire/
# 可自定义，例如：ECO_ACQUIRE_HOME=E:\literature-output
# ECO_ACQUIRE_HOME=
