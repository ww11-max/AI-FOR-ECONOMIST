# eco-acquire 环境变量配置
# 复制此文件为 .env 并修改

# ============================================================
# 浏览器配置
# ============================================================
# 浏览器选择：auto / chrome / edge / firefox
# auto = 自动检测系统已安装的浏览器（Chrome > Edge > Firefox）
BROWSER=auto

# 无头模式（不显示浏览器窗口）
USE_HEADLESS=False

# 调试模式
DEBUG=True

# 禁用SSL证书验证（仅在有证书问题时启用，默认false）
UNSAFE_SSL=False

# ============================================================
# 爬虫行为
# ============================================================
MAX_RETRIES=3
REQUEST_TIMEOUT=30
WAIT_TIME_MIN=2.0
WAIT_TIME_MAX=5.0

# ============================================================
# 数据目录
# ============================================================
# 输出/日志的存放位置，默认 ~/eco-acquire/
# 可自定义，例如：ECO_ACQUIRE_HOME=E:\literature-output
# ECO_ACQUIRE_HOME=
